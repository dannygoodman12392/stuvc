# Anthropic API Key for all AI features
ANTHROPIC_API_KEY=

# JWT Secret for team authentication
JWT_SECRET=your-secret-key-here

# Encryption-at-rest master key for user-supplied provider credentials in user_settings.
# 64-char hex (openssl rand -hex 32) preferred; any strong passphrase also works.
# If unset, credentials are stored as plaintext (dev only). Once set, new writes are
# encrypted and existing keys are migrated on the next boot. Do NOT rotate without
# re-entering keys — old ciphertext becomes undecryptable.
SETTINGS_ENC_KEY=

# Soft daily spend cap (USD) applied to non-owner users' metered LLM usage.
# The owner (admin / user_id 1) is uncapped. Default 10.
DEFAULT_DAILY_SPEND_CAP_USD=10

# Sourcing engine API keys
PROXYCURL_API_KEY=
HARMONIC_API_KEY=
CRUNCHBASE_API_KEY=
TWITTER_BEARER_TOKEN=
GITHUB_TOKEN=

# Notifications
SLACK_WEBHOOK_URL=

# Optional enrichment
CLEARBIT_API_KEY=

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Pipeline Configuration
PIPELINE_ENABLED=true
PIPELINE_CRON=0 6 * * *

# Notion (Strider OS) sync — fires when founder added to investment pipeline
NOTION_API_KEY=
NOTION_FOUNDERS_DB_ID=
NOTION_ASSESSMENTS_DB_ID=
STU_BASE_URL=https://stu.vc
