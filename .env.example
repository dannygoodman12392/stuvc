# Anthropic API Key for all AI features
ANTHROPIC_API_KEY=

# JWT Secret for team authentication
JWT_SECRET=your-secret-key-here

# Sourcing engine API keys
PROXYCURL_API_KEY=
HARMONIC_API_KEY=
CRUNCHBASE_API_KEY=
TWITTER_BEARER_TOKEN=
GITHUB_TOKEN=

# Notifications
SLACK_WEBHOOK_URL=

# Optional enrichment
CLEARBIT_API_KEY=

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Pipeline Configuration
PIPELINE_ENABLED=true
PIPELINE_CRON=0 6 * * *
